{
  "name": "riskblue-export-worker",
  "version": "1.0.0",
  "description": "Background worker that generates DOCX exports for RiskBlue analysis requests and emails 15-day signed download links.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.56",
    "@supabase/supabase-js": "^2.45.0",
    "date-fns": "^3.6.0",
    "docx": "^9.0.2",
    "dotenv": "^16.4.5",
    "pdfjs-dist": "^4.7.76"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
